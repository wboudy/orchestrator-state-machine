{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrator-state-machine.local/contracts/orchestrator_policy.schema.json",
  "title": "Orchestrator Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timezone",
    "business_hours",
    "retry",
    "risk_budget",
    "dedupe",
    "trust"
  ],
  "properties": {
    "timezone": {
      "type": "string",
      "pattern": "^[A-Za-z_]+(?:/[A-Za-z0-9_+.-]+)+$",
      "minLength": 3
    },
    "business_hours": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weekdays",
        "start",
        "end"
      ],
      "properties": {
        "weekdays": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri",
              "Sat",
              "Sun"
            ]
          }
        },
        "start": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_retries",
        "backoff_seconds",
        "jitter_pct"
      ],
      "properties": {
        "max_retries": {
          "type": "integer",
          "minimum": 0
        },
        "backoff_seconds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "jitter_pct": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "risk_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_noncritical_escalations_per_day",
        "max_noncritical_pages_per_hour"
      ],
      "properties": {
        "max_noncritical_escalations_per_day": {
          "type": "integer",
          "minimum": 0
        },
        "max_noncritical_pages_per_hour": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "dedupe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_minutes"
      ],
      "properties": {
        "window_minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_score",
        "min_samples"
      ],
      "properties": {
        "initial_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_samples": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
